# Copy to ~/.config/x-post/credentials.env (chmod 600)
#
# NOT developer.x.com — use your BROWSER while logged into x.com:
#   Chrome: Cmd+Option+I → Application → Cookies → https://x.com
#   Or: Network tab → reload → click x.com request → Request Headers → cookie:
#   Copy: auth_token  and  ct0

AUTH_TOKEN=your_auth_token_here
CT0=your_ct0_here

# Optional: prefer a specific browser for automatic cookie extraction
# BIRD_COOKIE_SOURCE=chrome
# BIRD_CHROME_PROFILE=Default