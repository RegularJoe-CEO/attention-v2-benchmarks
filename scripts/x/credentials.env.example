# Copy to ~/.config/x-post/credentials.env (chmod 600)
# Get values: x.com (logged in) → DevTools → Application → Cookies → x.com
#   auth_token  — HttpOnly cookie
#   ct0         — visible cookie (also sent as x-csrf-token)

AUTH_TOKEN=your_auth_token_here
CT0=your_ct0_here

# Optional: prefer a specific browser for automatic cookie extraction
# BIRD_COOKIE_SOURCE=chrome
# BIRD_CHROME_PROFILE=Default